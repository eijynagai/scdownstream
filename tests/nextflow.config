/*
========================================================================================
    Nextflow config file for running tests
========================================================================================
*/

process {
    withName: SCVITOOLS_SCVI {
        ext.max_epochs = 5
    }
    withName: SCVITOOLS_SCANVI {
        ext.max_epochs = 5
    }
    withName: SCVITOOLS_SOLO {
        ext.max_epochs = 1
    }
    withName: CELLBENDER_REMOVEBACKGROUND {
        ext.args = '--epochs 2'
    }
    withName: SCVITOOLS_SCAR {
        ext.max_epochs = 1
    }

    resourceLimits = [
        cpus: 4,
        memory: '6.GB',
        time: '1.h'
    ]
}
