/*
========================================================================================
    Nextflow config file for running nf-test tests
========================================================================================
*/

params.modules_testdata_base_path = 'https://raw.githubusercontent.com/nf-core/test-datasets/modules/data/'
params.pipelines_testdata_base_path = 'https://raw.githubusercontent.com/nf-core/test-datasets/refs/heads/scdownstream'

aws.client.anonymous = true // fixes S3 access issues on self-hosted runners

process {
    withName: SCVITOOLS_SCVI {
        ext.max_epochs = 5
    }
    withName: SCVITOOLS_SCANVI {
        ext.max_epochs = 5
    }
    withName: SCVITOOLS_SOLO {
        ext.max_epochs = 1
    }
    withName: CELLBENDER_REMOVEBACKGROUND {
        ext.args = '--epochs 2'
    }
    withName: SCVITOOLS_SCAR {
        ext.max_epochs = 1
    }
}
