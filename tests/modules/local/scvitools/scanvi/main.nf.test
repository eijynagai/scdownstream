nextflow_process {

    name "Test Process SCVITOOLS_SCANVI"
    script "modules/local/scvitools/scanvi/main.nf"
    process "SCVITOOLS_SCANVI"

    test("Should run without failures") {

        config "./nextflow.config"

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = Channel.of([
                        [ id: 'test' ],
                        file(params.pipelines_testdata_base_path + 'samples/SAMN14430799_raw_matrix_subset_with_batch.h5ad', checkIfExists: true)
                    ]
                )
                input[1] = [[], []]
                input[2] = 'batch'
                input[3] = ''
                input[4] = ''
                """
            }
        }

        then {
            assertAll(
            { assert process.success },
            { assert snapshot(
                    process.out.h5ad,
                    process.out.obs,
                    process.out.obsm,
                    process.out.versions
                ).match()
            },
            )
        }

    }

    test("Should run without failures - stub") {

        options '-stub'
        config "./nextflow.config"

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = Channel.of([
                        [ id: 'test' ],
                        file(params.pipelines_testdata_base_path + 'samples/SAMN14430799_raw_matrix_subset_with_batch.h5ad', checkIfExists: true)
                    ]
                )
                input[1] = [[], []]
                input[2] = 'batch'
                input[3] = ''
                input[4] = ''
                """
            }
        }

        then {
            assertAll(
            { assert process.success },
            { assert snapshot(process.out).match() }
            )
        }

    }

}
