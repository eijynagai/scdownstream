nextflow_process {

    name "Test Process ADATA_UNIFY"
    script "modules/local/adata/unify/main.nf"
    process "ADATA_UNIFY"

    test("Should run without failures") {

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = Channel.of([
                        [id: 'test'],
                        file(params.pipelines_testdata_base_path + 'pbmc/combined_filtered_matrix.h5ad', checkIfExists: true)
                    ]
                )
                input[1] = 'sample'
                input[2] = ''
                input[3] = 'unknown'
                input[4] = 'index'
                input[5] = 'X'
                input[6] = 'make_unique'
                """
            }
        }

        then {
            assertAll(
            { assert process.success },
            { assert snapshot(process.out).match() }
            )
        }

    }

    test("Should run without failures - stub") {

        options '-stub'

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = Channel.of([
                        [id: 'test'],
                        file(params.pipelines_testdata_base_path + 'pbmc/combined_filtered_matrix.h5ad', checkIfExists: true)
                    ]
                )
                input[1] = 'sample'
                input[2] = ''
                input[3] = 'unknown'
                input[4] = 'index'
                input[5] = 'X'
                input[6] = 'make_unique'
                """
            }
        }

        then {
            assertAll(
            { assert process.success },
            { assert snapshot(process.out).match() }
            )
        }

    }

}
