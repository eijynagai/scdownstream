nextflow_process {

    name "Test Process ADATA_MYGENE"
    script "modules/local/adata/mygene/main.nf"
    process "ADATA_MYGENE"

    test("Should run without failures") {

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = Channel.of([
                        [id: 'test'],
                        file(params.pipelines_testdata_base_path + 'pbmc/SRR28679759_filtered_matrix.h5ad', checkIfExists: true)
                    ]
                )
                """
            }
        }

        then {
            assertAll(
            { assert process.success },
            { assert snapshot(process.out).match() }
            )
        }

    }

    test("Should run without failures - stub") {

        options '-stub'

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = Channel.of([
                        [id: 'test'],
                        file(params.pipelines_testdata_base_path + 'pbmc/SRR28679759_filtered_matrix.h5ad', checkIfExists: true)
                    ]
                )
                """
            }
        }

        then {
            assertAll(
            { assert process.success },
            { assert snapshot(process.out).match() }
            )
        }

    }

}
