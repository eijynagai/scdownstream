nextflow_process {

    name "Test Process ADATA_MERGE"
    script "modules/local/adata/merge/main.nf"
    process "ADATA_MERGE"

    setup {
        run("ADATA_UNIFY") {
            script "modules/local/adata/unify/main.nf"
            process {
                """
                input[0] = Channel.of([
                        [id: 'test1'],
                        file(params.pipelines_testdata_base_path + 'pbmc3k/pbmc3k_processed.h5ad', checkIfExists: true)
                    ], [
                        [id: 'test2'],
                        file(params.pipelines_testdata_base_path + 'pbmc3k/pbmc3k_processed.h5ad', checkIfExists: true)
                    ], [
                        [id: 'test3'],
                        file(params.pipelines_testdata_base_path + 'pbmc3k/pbmc3k_processed.h5ad', checkIfExists: true)
                    ]
                )
                """
            }
        }
    }

    test("Should run without base") {

        when {
            params {
                // define parameters here. Example:
                // outdir = "tests/results"
            }
            process {
                """
                input[0] = ADATA_UNIFY.out.h5ad
                input[1] = [[], []]
                """
            }
        }

        then {
            assert process.success
            assert snapshot(process.out).match()
        }

    }


    test("Should run with base") {

        when {
            params {
                // define parameters here. Example:
                // outdir = "tests/results"
            }
            process {
                """
                ch_h5ad = ADATA_UNIFY.out.h5ad.branch{ meta, h5ad ->
                    samples: meta.id in ['test1', 'test2']
                    base: meta.id == 'test3'
                }
                input[0] = ch_h5ad.samples
                input[1] = ch_h5ad.base
                """
            }
        }

        then {
            assert process.success
            assert snapshot(process.out).match()
        }

    }

    test("Should run with base - stub") {

        options '-stub'

        when {
            params {
                // define parameters here. Example:
                // outdir = "tests/results"
            }
            process {
                """
                ch_h5ad = ADATA_UNIFY.out.h5ad.branch{ meta, h5ad ->
                    samples: meta.id in ['test1', 'test2']
                    base: meta.id == 'test3'
                }
                input[0] = ch_h5ad.samples
                input[1] = ch_h5ad.base
                """
            }
        }

        then {
            assert process.success
            assert snapshot(process.out).match()
        }

    }
}
