nextflow_process {

    name "Test Process HUGOUNIFIER_APPLY"
    script "modules/local/hugounifier/apply/main.nf"
    process "HUGOUNIFIER_APPLY"

    setup {
        run("HUGOUNIFIER_GET") {
            script "modules/local/hugounifier/get/main.nf"
            process {
                """
                input[0] = Channel.of([
                        [ id: 'test' ],
                        [
                            "test1",
                        ],
                        [
                            file(params.pipelines_testdata_base_path + 'pbmc3k/pbmc3k_processed.h5ad', checkIfExists: true),
                        ]
                    ]
                )
                """
            }
        }
    }

    test("Should run without failures") {

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                ch_h5ad = Channel.of([
                        [ id: 'test1' ],
                        [
                            file(params.pipelines_testdata_base_path + 'pbmc3k/pbmc3k_processed.h5ad', checkIfExists: true),
                        ]
                    ]
                )
                ch_changes = HUGOUNIFIER_GET.out.changes
                    .map { _meta, changes -> [changes] }
                    .flatten()
                    .map { changes -> [changes.baseName, changes] }
                    .join(
                        ch_h5ad.map{ meta, h5ad -> [meta.id, meta, h5ad] }
                    )
                    .map { _id, changes, meta, h5ad ->
                        [meta, h5ad, changes]
                    }

                input[0] = ch_changes
                """
            }
        }

        then {
            assertAll(
            { assert process.success },
            { assert snapshot(process.out).match() }
            )
        }

    }

    test("Should run without failures - stub") {

        options '-stub'

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                ch_h5ad = Channel.of([
                        [ id: 'test1' ],
                        [
                            file(params.pipelines_testdata_base_path + 'pbmc3k/pbmc3k_processed.h5ad', checkIfExists: true),
                        ]
                    ]
                )
                ch_changes = HUGOUNIFIER_GET.out.changes
                    .map { _meta, changes -> [changes] }
                    .flatten()
                    .map { changes -> [changes.baseName, changes] }
                    .join(
                        ch_h5ad.map{ meta, h5ad -> [meta.id, meta, h5ad] }
                    )
                    .map { _id, changes, meta, h5ad ->
                        [meta, h5ad, changes]
                    }

                input[0] = ch_changes
                """
            }
        }

        then {
            assertAll(
            { assert process.success },
            { assert snapshot(process.out).match() }
            )
        }

    }

}
