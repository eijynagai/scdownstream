nextflow_process {

    name "Test Process SCANPY_NEIGHBORS"
    script "modules/local/scanpy/neighbors/main.nf"
    process "SCANPY_NEIGHBORS"

    setup {
        run("SCANPY_PCA") {
            script "modules/local/scanpy/pca/main.nf"
            process {
                """
                input[0] = Channel.of([
                        [ id: 'test' ],
                        file(params.pipelines_testdata_base_path + 'lupus/samples/sarin.h5ad', checkIfExists: true)
                    ]
                )
                """
            }
        }
    }

    test("Should run without failures") {

        config "./nextflow.config"

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = SCANPY_PCA.out.h5ad
                """
            }
        }

        then {
            assertAll(
            { assert process.success },
            { assert snapshot(process.out).match() }
            )
        }

    }

    test("Should run without failures - stub") {

        options '-stub'

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = SCANPY_PCA.out.h5ad
                """
            }
        }

        then {
            assertAll(
            { assert process.success },
            { assert snapshot(process.out).match() }
            )
        }

    }

}
