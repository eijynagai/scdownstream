nextflow_process {

    name "Test Process SCANPY_COMBAT"
    script "modules/local/scanpy/combat/main.nf"
    process "SCANPY_COMBAT"

    test("Should run without failures") {

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = Channel.of([
                        [ id: 'test' ],
                        file(params.pipelines_testdata_base_path + 'samples/SAMN14430799_raw_matrix_subset_with_batch.h5ad', checkIfExists: true)
                    ]
                )
                """
            }
        }

        then {
            assertAll(
            { assert process.success },
            { assert snapshot(process.out).match() }
            )
        }

    }

    test("Should run without failures - stub") {

        options '-stub'

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = Channel.of([
                        [ id: 'test' ],
                        file(params.pipelines_testdata_base_path + 'samples/SAMN14430799_raw_matrix_subset_with_batch.h5ad', checkIfExists: true)
                    ]
                )
                """
            }
        }

        then {
            assertAll(
            { assert process.success },
            { assert snapshot(process.out).match() }
            )
        }

    }

}
