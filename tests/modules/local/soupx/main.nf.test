nextflow_process {

    name "Test Process SOUPX"
    script "modules/local/soupx/main.nf"
    process "SOUPX"

    test("Should run without failures") {

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = Channel.of([
                        [ id: 'test' ],
                        file(params.pipelines_testdata_base_path + 'samples/SAMN14430799_custom_emptydrops_filter_matrix.h5ad', checkIfExists: true),
                        file(params.pipelines_testdata_base_path + 'samples/SAMN14430799_raw_matrix.h5ad', checkIfExists: true)
                    ]
                )
                """
            }
        }

        then {
            assertAll(
            { assert process.success },
            { assert snapshot(process.out).match() }
            )
        }

    }

    test("Should run without failures - prefix") {

        config './nextflow.config'

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = Channel.of([
                        [ id: 'test' ],
                        file(params.pipelines_testdata_base_path + 'samples/SAMN14430799_custom_emptydrops_filter_matrix.h5ad', checkIfExists: true),
                        file(params.pipelines_testdata_base_path + 'samples/SAMN14430799_raw_matrix.h5ad', checkIfExists: true)
                    ]
                )
                """
            }
        }

        then {
            assertAll(
            { assert process.success },
            { assert snapshot(process.out).match() }
            )
        }

    }

    test("Should run without failures - stub") {

        options '-stub'

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = Channel.of([
                        [ id: 'test' ],
                        file(params.pipelines_testdata_base_path + 'samples/SAMN14430799_custom_emptydrops_filter_matrix.h5ad', checkIfExists: true),
                        file(params.pipelines_testdata_base_path + 'samples/SAMN14430799_raw_matrix.h5ad', checkIfExists: true)
                    ]
                )
                """
            }
        }

        then {
            assertAll(
            { assert process.success },
            { assert snapshot(process.out).match() }
            )
        }

    }

    test("Should run without failures - prefix - stub") {

        options '-stub'
        config './nextflow.config'

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = Channel.of([
                        [ id: 'test' ],
                        file(params.pipelines_testdata_base_path + 'samples/SAMN14430799_custom_emptydrops_filter_matrix.h5ad', checkIfExists: true),
                        file(params.pipelines_testdata_base_path + 'samples/SAMN14430799_raw_matrix.h5ad', checkIfExists: true)
                    ]
                )
                """
            }
        }

        then {
            assertAll(
            { assert process.success },
            { assert snapshot(process.out).match() }
            )
        }

    }

}
