nextflow_process {

    name "Test Process SOUPX"
    script "modules/local/soupx/main.nf"
    process "SOUPX"

    test("Should run without failures") {

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = Channel.of([
                        [ id: 'test' ],
                        file(params.pipelines_testdata_base_path + 'pbmc/SRR28679759_filtered_matrix.h5ad', checkIfExists: true),
                        file(params.pipelines_testdata_base_path + 'pbmc/SRR28679759_raw_matrix.h5ad', checkIfExists: true)
                    ]
                )
                input[1] = "X"
                """
            }
        }

        then {
            assertAll(
            { assert process.success },
            { assert snapshot(
                // Hashing does not work due to this issue:
                // https://github.com/scverse/anndataR/issues/272
                process.out.versions,
                file(process.out.h5ad.get(0).get(1)).exists(),
                file(process.out.h5ad.get(0).get(1)).size()
            ).match() }
            )
        }

    }

    test("Should run without failures - stub") {

        options '-stub'

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = Channel.of([
                        [ id: 'test' ],
                        file(params.pipelines_testdata_base_path + 'pbmc/SRR28679759_filtered_matrix.h5ad', checkIfExists: true),
                        file(params.pipelines_testdata_base_path + 'pbmc/SRR28679759_raw_matrix.h5ad', checkIfExists: true)
                    ]
                )
                input[1] = "X"
                """
            }
        }

        then {
            assertAll(
            { assert process.success },
            { assert snapshot(process.out).match() }
            )
        }

    }

}
