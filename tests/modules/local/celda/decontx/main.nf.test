nextflow_process {

    name "Test Process CELDA_DECONTX"
    script "modules/local/celda/decontx/main.nf"
    process "CELDA_DECONTX"

    test("Should run without failures without raw - single batch") {

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = Channel.of([
                        [ id: 'test' ],
                        file(params.pipelines_testdata_base_path + 'scrnaseq/Sample_X/Sample_X_filtered_matrix.h5ad', checkIfExists: true),
                        []
                    ]
                )
                input[1] = "sample"
                input[2] = "counts"
                """
            }
        }

        then {
            assertAll(
            { assert process.success },
            { assert snapshot(process.out).match() }
            )
        }

    }

    test("Should run without failures without raw - multi-batch") {

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = Channel.of([
                        [ id: 'test' ],
                        file(params.pipelines_testdata_base_path + 'scrnaseq/Sample_X/Sample_X_filtered_matrix.h5ad', checkIfExists: true),
                        []
                    ]
                )
                input[1] = "leiden"
                input[2] = "counts"
                """
            }
        }

        then {
            assertAll(
            { assert process.success },
            { assert snapshot(process.out).match() }
            )
        }

    }

    test("Should run without failures without raw - stub") {

        options '-stub'

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = Channel.of([
                        [ id: 'test' ],
                        file(params.pipelines_testdata_base_path + 'scrnaseq/Sample_X/Sample_X_filtered_matrix.h5ad', checkIfExists: true),
                        []
                    ]
                )
                input[1] = "leiden"
                input[2] = "counts"
                """
            }
        }

        then {
            assertAll(
            { assert process.success },
            { assert snapshot(process.out).match() }
            )
        }

    }

    test("Should run without failures with raw") {

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = Channel.of([
                        [ id: 'test' ],
                        file(params.pipelines_testdata_base_path + 'scrnaseq/Sample_X/Sample_X_filtered_matrix.h5ad', checkIfExists: true),
                        file(params.pipelines_testdata_base_path + 'scrnaseq/Sample_X/Sample_X_raw_matrix.h5ad', checkIfExists: true)
                    ]
                )
                input[1] = "leiden"
                input[2] = "counts"
                """
            }
        }

        then {
            assertAll(
            { assert process.success },
            { assert snapshot(process.out).match() }
            )
        }

    }

    test("Should run without failures with raw - stub") {

        options '-stub'

        when {
            params {
                outdir = "$outputDir"
            }
            process {
                """
                input[0] = Channel.of([
                        [ id: 'test' ],
                        file(params.pipelines_testdata_base_path + 'scrnaseq/Sample_X/Sample_X_filtered_matrix.h5ad', checkIfExists: true),
                        file(params.pipelines_testdata_base_path + 'scrnaseq/Sample_X/Sample_X_raw_matrix.h5ad', checkIfExists: true)
                    ]
                )
                input[1] = "leiden"
                input[2] = "counts"
                """
            }
        }

        then {
            assertAll(
            { assert process.success },
            { assert snapshot(process.out).match() }
            )
        }

    }

}
