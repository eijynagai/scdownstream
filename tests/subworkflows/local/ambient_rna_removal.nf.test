    test("Should run with 'scar' ambient removal") {

        config './ambient_rna_removal.config'

        when {
            params {
                outdir = "$outputDir"
                ambient_removal = 'scar'
            }
            workflow {
                """
                input[0] = Channel.of([
                        [ id: 'test' ],
                        file(params.pipelines_testdata_base_path + 'samples/SAMN14430799_custom_emptydrops_filter_matrix.h5ad', checkIfExists: true),
                        file(params.pipelines_testdata_base_path + 'samples/SAMN14430799_raw_matrix.h5ad', checkIfExists: true)
                    ]
                )
                """
            }
        }

        then {
            assert workflow.success
