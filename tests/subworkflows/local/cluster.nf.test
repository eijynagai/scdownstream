nextflow_workflow {

    name "Test Workflow CLUSTER"
    script "subworkflows/local/cluster.nf"
    workflow "CLUSTER"

    setup {

        run("ADATA_UNIFY") {
            script "modules/local/adata/unify/main.nf"
            process {
                """
                input[0] = Channel.of([
                        [ id: 'test' ],
                        file(params.pipelines_testdata_base_path + 'pbmc/combined_filtered_matrix.h5ad', checkIfExists: true)
                    ]
                )
                input[1] = 'sample'
                input[2] = 'leiden'
                input[3] = 'unknown'
                input[4] = 'index'
                input[5] = 'X'
                input[6] = 'make_unique'
                """
            }
        }
        run("SCANPY_PCA") {
            script "modules/local/scanpy/pca/main.nf"
            process {
                """
                input[0] = ADATA_UNIFY.out.h5ad.map{ meta, h5ad -> [meta + [integration: 'pca'], h5ad] }
                """
            }
        }
    }

    test("Should run without failures - global - stub") {

        options '-stub'
        config './cluster.config'

        when {
            params {
                outdir = "$outputDir"
            }
            workflow {
                """
                input[0] = SCANPY_PCA.out.h5ad
                input[1] = false
                input[2] = true
                input[3] = ''
                input[4] = Channel.of('0.5', '1')
                """
            }
        }

        then {
            assert workflow.success
            assert snapshot(workflow.out).match()
        }

    }

    test("Should run without failures - global") {

        config './cluster.config'

        when {
            params {
                outdir = "$outputDir"
            }
            workflow {
                """
                input[0] = SCANPY_PCA.out.h5ad
                input[1] = false
                input[2] = true
                input[3] = ''
                input[4] = Channel.of('0.5', '1')
                """
            }
        }

        then {
            assert workflow.success
            assert snapshot(workflow.out).match()
        }

    }

    test("Should run without failures - per-label - stub") {

        options '-stub'
        config './cluster.config'

        when {
            params {
                outdir = "$outputDir"
            }
            workflow {
                """
                input[0] = SCANPY_PCA.out.h5ad
                input[1] = true
                input[2] = false
                input[3] = 'batch'
                input[4] = Channel.of('0.5', '1')
                """
            }
        }

        then {
            assert workflow.success
            assert snapshot(workflow.out).match()
        }

    }

    test("Should run without failures - per-label") {

        config './cluster.config'

        when {
            params {
                outdir = "$outputDir"
            }
            workflow {
                """
                input[0] = SCANPY_PCA.out.h5ad
                input[1] = true
                input[2] = false
                input[3] = 'batch'
                input[4] = Channel.of('0.5', '1')
                """
            }
        }

        then {
            assert workflow.success
            assert snapshot(workflow.out).match()
        }

    }

    test("Should run without failures - both - stub") {

        options '-stub'
        config './cluster.config'

        when {
            params {
                outdir = "$outputDir"
            }
            workflow {
                """
                input[0] = SCANPY_PCA.out.h5ad
                input[1] = true
                input[2] = true
                input[3] = 'batch'
                input[4] = Channel.of('0.5', '1')
                """
            }
        }

        then {
            assert workflow.success
            assert snapshot(workflow.out).match()
        }

    }

    test("Should run without failures - both") {

        config './cluster.config'

        when {
            params {
                outdir = "$outputDir"
            }
            workflow {
                """
                input[0] = SCANPY_PCA.out.h5ad
                input[1] = true
                input[2] = true
                input[3] = 'batch'
                input[4] = Channel.of('0.5', '1')
                """
            }
        }

        then {
            assert workflow.success
            assert snapshot(workflow.out).match()
        }

    }

}
