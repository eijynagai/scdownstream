nextflow_workflow {

    name "Test Workflow PSEUDOBULKING"
    script "subworkflows/local/pseudobulking.nf"
    workflow "PSEUDOBULKING"

    test("Should run without failures") {

        config './pseudobulking.config'

        when {
            params {
                outdir = "$outputDir"
            }
            workflow {
                """
                input[0] = Channel.of([
                        [id: 'test'],
                        file(params.pipelines_testdata_base_path + 'lupus/base/merged.h5ad', checkIfExists: true)
                    ]
                )
                """
            }
        }

        then {
            assert workflow.success
            assert snapshot(workflow.out).match()
        }

    }

    test("Should run without failures - stub") {

        options '-stub'
        config './pseudobulking.config'

        when {
            params {
                outdir = "$outputDir"
            }
            workflow {
                """
                input[0] = Channel.of([
                        [id: 'test'],
                        file(params.pipelines_testdata_base_path + 'lupus/base/merged.h5ad', checkIfExists: true)
                    ]
                )
                """
            }
        }

        then {
            assert workflow.success
            assert snapshot(workflow.out).match()
        }

    }

}
