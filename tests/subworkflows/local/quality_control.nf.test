nextflow_workflow {

    name "Test Workflow QUALITY_CONTROL"
    script "subworkflows/local/quality_control.nf"
    workflow "QUALITY_CONTROL"

    test("Should run without ambient RNA removal and doublet detection") {

        config './quality_control.config'

        when {
            params {
                outdir = "$outputDir"
                ambient_removal = 'none'
                doublet_detection = 'none'
            }
            workflow {
                """
                input[0] = Channel.of([
                        [ id: 'test' ],
                        file(params.pipelines_testdata_base_path + 'samples/SAMN14430799_custom_emptydrops_filter_matrix.h5ad', checkIfExists: true),
                        file(params.pipelines_testdata_base_path + 'samples/SAMN14430799_raw_matrix.h5ad', checkIfExists: true)
                    ]
                )
                """
            }
        }

        then {
            assert workflow.success
            assert snapshot(workflow.out).match()
        }

    }

    test("Should run with ambient RNA removal and doublet detection") {

        config './quality_control.config'

        when {
            params {
                outdir = "$outputDir"
                ambient_removal = 'decontx'
                doublet_detection = 'scrublet'
            }
            workflow {
                """
                input[0] = Channel.of([
                        [ id: 'test' ],
                        file(params.pipelines_testdata_base_path + 'samples/SAMN14430799_custom_emptydrops_filter_matrix.h5ad', checkIfExists: true),
                        file(params.pipelines_testdata_base_path + 'samples/SAMN14430799_raw_matrix.h5ad', checkIfExists: true)
                    ]
                )
                """
            }
        }

        then {
            assert workflow.success
            assert snapshot(workflow.out).match()
        }

    }

    test("Should run with ambient RNA removal and doublet detection - stub") {

        options '-stub'
        config './quality_control.config'

        when {
            params {
                outdir = "$outputDir"
                ambient_removal = 'decontx'
                doublet_detection = 'scrublet'
            }
            workflow {
                """
                input[0] = Channel.of([
                        [ id: 'test' ],
                        file(params.pipelines_testdata_base_path + 'samples/SAMN14430799_custom_emptydrops_filter_matrix.h5ad', checkIfExists: true),
                        file(params.pipelines_testdata_base_path + 'samples/SAMN14430799_raw_matrix.h5ad', checkIfExists: true)
                    ]
                )
                """
            }
        }

        then {
            assert workflow.success
            assert snapshot(workflow.out).match()
        }

    }

}
