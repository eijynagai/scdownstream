nextflow_workflow {

    name "Test Workflow DOUBLET_DETECTION"
    script "subworkflows/local/doublet_detection.nf"
    workflow "DOUBLET_DETECTION"

    test("Should run without methods") {

        config './doublet_detection.config'

        when {
            params {
                outdir = "$outputDir"
                doublet_detection = ""
            }
            workflow {
                """
                input[0] = Channel.of([
                        [ id: 'test' ],
                        file(params.pipelines_testdata_base_path + 'samples/SAMN14430799_custom_emptydrops_filter_matrix.h5ad', checkIfExists: true)
                    ]
                )
                """
            }
        }

        then {
            assertAll(
            { assert workflow.success },
            { assert workflow.trace.tasks().size() == 0 }
            )
        }

    }

    test("Should run with 'none' method") {

        config './doublet_detection.config'

        when {
            params {
                outdir = "$outputDir"
                doublet_detection = "none"
            }
            workflow {
                """
                input[0] = Channel.of([
                        [ id: 'test' ],
                        file(params.pipelines_testdata_base_path + 'samples/SAMN14430799_custom_emptydrops_filter_matrix.h5ad', checkIfExists: true)
                    ]
                )
                """
            }
        }

        then {
            assertAll(
            { assert workflow.success },
            { assert workflow.trace.tasks().size() == 0 }
            )
        }

    }

    test("Should run with all methods") {

        config './doublet_detection.config'

        when {
            params {
                outdir = "$outputDir"
                doublet_detection = "scds,solo,scrublet,doubletdetection"
            }
            workflow {
                """
                input[0] = Channel.of([
                        [ id: 'test' ],
                        file(params.pipelines_testdata_base_path + 'samples/SAMN14430799_custom_emptydrops_filter_matrix.h5ad', checkIfExists: true)
                    ]
                )
                """
            }
        }

        then {
            assertAll(
            { assert workflow.success },
            { assert snapshot(workflow.out).match() }
            )
        }

    }

    test("Should run without failures - stub") {

        options '-stub'
        config './doublet_detection.config'
        when {
            params {
                outdir = "$outputDir"
                doublet_detection = "scds,solo,scrublet,doubletdetection"
            }
            workflow {
                """
                input[0] = Channel.of([
                        [ id: 'test' ],
                        file(params.pipelines_testdata_base_path + 'samples/SAMN14430799_custom_emptydrops_filter_matrix.h5ad', checkIfExists: true)
                    ]
                )
                """
            }
        }

        then {
            assertAll(
            { assert workflow.success },
            { assert snapshot(workflow.out).match() }
            )
        }

    }

}
